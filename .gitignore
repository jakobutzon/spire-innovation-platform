# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# .env.production holder KUN offentlige NEXT_PUBLIC-nøgler (Supabase anon-key er
# designet til at ligge i browser-bundlen og er beskyttet af RLS) — committes med vilje
# så Vercel-builds har config uden manuel opsætning.
!.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
