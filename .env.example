# Supabase — find disse i dit Supabase-projekt under Settings → API.
# Begge er offentlige nøgler (bruges i browseren) og skal sættes som Environment
# Variables i Vercel (Production + Preview) samt lokalt i .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
